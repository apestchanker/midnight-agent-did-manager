# Midnight Preprod frontend configuration
VITE_NETWORK_ID=preprod
VITE_INDEXER_URI=https://indexer.preprod.midnight.network/api/v3/graphql
VITE_INDEXER_WS_URI=wss://indexer.preprod.midnight.network/api/v3/graphql/ws
VITE_NODE_URI=https://rpc.preprod.midnight.network
VITE_PROVER_SERVER_URI=http://127.0.0.1:6300
VITE_MANAGED_CONTRACT_PATH=/contracts/managed/did-registry
VITE_APP_TITLE="Midnight Agent DID Manager"
VITE_APP_VERSION=0.3.0
VITE_CONTRACT_VERSION=0.3.0

# Alternative Preview network configuration
# Uncomment and replace the values above if you want to target Preview instead of Preprod.
# VITE_NETWORK_ID=preview
# VITE_INDEXER_URI=https://indexer.preview.midnight.network/api/v3/graphql
# VITE_INDEXER_WS_URI=wss://indexer.preview.midnight.network/api/v3/graphql/ws
# VITE_NODE_URI=https://rpc.preview.midnight.network
# VITE_PROVER_SERVER_URI=http://127.0.0.1:6300

# DID service / MCP API
VITE_DID_API_BASE_URL=http://localhost:8787
DID_API_PORT=8787
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD_HERE@127.0.0.1:5432/agent_registry_db

# Optional admin wallet override for UI role gating
VITE_ADMIN_WALLET_SHIELDED_ADDR=mn_shield-addr_XXXXXXXX

# Owner authorization now uses a random local vault secret stored in Midnight
# private state. Export an encrypted backup from the UI after deployment.
# Backup passwords must be at least 10 characters.
